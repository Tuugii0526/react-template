{
	"name": "bun-react-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev:api": "NODE_ENV=development bun --hot backend/src/index.ts",
		"prod": "NODE_ENV=production bun backend/src/index.ts",
		"dev:web": "vite frontend",
		"build": "tsc -b && vite build frontend",
		"typecheck": "tsc -b",
		"preview": "vite preview frontend",
		"lint": "biome check --write .",
		"lint:ci": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@hono/swagger-ui": "^0.5.1",
		"@hono/zod-openapi": "^1.1.4",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-router": "^1.170.15",
		"hono": "^4.12.15",
		"react": "^19",
		"react-dom": "^19",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.2",
		"@tanstack/react-router-devtools": "^1.167.0",
		"@tanstack/router-plugin": "^1.168.18",
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
