{
	// Frontend (browser). Sits next to the code it checks; includes all of frontend/ by default.
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "../node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["react"],
		"paths": { "@/*": ["./*"], "@api/*": ["../backend/src/*"] }
	},
	// vite.config.ts uses Node APIs; it is type-checked by the Node/Bun project
	// (backend/tsconfig.json) instead, so exclude it here to avoid double project
	// membership.
	"exclude": ["vite.config.ts"]
}
